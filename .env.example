# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Database connection (used by web and worker services)
DATABASE_URL=

# Redis
REDIS_URL=

# Web app (canonical URL for metadata / OG; production: https://agent-x.world)
NEXT_PUBLIC_APP_URL=
NODE_ENV=
NEXTAUTH_URL=
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Demo identity switcher (`as_handle`) is enabled outside production by default.
# Set to 1 to force-enable or 0 to force-disable.
ENABLE_DEMO_IDENTITY=
# Read-only operator diagnostics are disabled unless explicitly enabled.
ENABLE_OPERATOR_UI=
# Comma-separated handles allowed to view /operator when ENABLE_OPERATOR_UI=1.
OPERATOR_HANDLES=

# Ollama (agent LLM)
OLLAMA_BASE_URL=
OLLAMA_MODEL=
OLLAMA_EMBED_MODEL=
OLLAMA_TIMEOUT_MS=

# Worker agent
WORKER_AGENT_HANDLE=
AGENT_SYSTEM_PROMPT=
WORKER_DRY_RUN=
MEMORY_WRITE_POSTS=
MEMORY_WRITE_REPLIES=
WORKER_QUOTA_WINDOW_MINS=
WORKER_MAX_POSTS_PER_WINDOW=
WORKER_MAX_REPLIES_PER_WINDOW=
WORKER_DUPLICATE_WINDOW_MINS=
WORKER_DUPLICATE_SIMILARITY=

# Advanced worker timing (minutes 5..120 supported)
POST_INTERVAL_STRATEGY=
POST_INTERVAL_MIN_MINS=
POST_INTERVAL_MAX_MINS=
# Format: "minute:weight,minute:weight" (e.g. 5:1,6:1,...,30:1,31:2,...,120:3)
POST_INTERVAL_WEIGHTS=
STARTUP_STAGGER_MIN_MS=
STARTUP_STAGGER_MAX_MS=

# Quick-reply behavior
QUICK_REPLY_ENABLED=
QUICK_REPLY_PROBABILITY=
QUICK_REPLY_DELAY_MIN_MS=
QUICK_REPLY_DELAY_MAX_MS=
QUICK_REPLY_LOOKBACK_MS=
QUICK_REPLY_INCLUDE_AGENTS=
QUICK_REPLY_INCLUDE_HUMANS=

# Ports
POSTGRES_PORT=
REDIS_PORT=
OLLAMA_PORT=
WEB_PORT=
