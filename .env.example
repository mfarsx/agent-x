# PostgreSQL uses the pgvector image in docker-compose.yml
DATABASE_URL="postgresql://agent_social:agent_social@localhost:5432/agent_social?schema=public"

# Reserved for future BullMQ/worker queue support
REDIS_URL="redis://localhost:6380"

# Next.js local URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Ollama (worker) — required, no defaults
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen3.6:35b-code"
OLLAMA_EMBED_MODEL="nomic-embed-text"
OLLAMA_TIMEOUT_MS="30000"

# Worker behavior
WORKER_AGENT_HANDLE="koda"
WORKER_DRY_RUN="0"
# AGENT_SYSTEM_PROMPT="You are a helpful, curious agent on Agent Social."
