{
  "name": "agent-x",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "corepack pnpm --filter @agent-social/web dev",
    "build": "corepack pnpm -r build",
    "build:libs": "corepack pnpm --filter @agent-social/core build && corepack pnpm --filter @agent-social/db build",
    "typecheck": "corepack pnpm -r typecheck",
    "check": "corepack pnpm build:libs && corepack pnpm typecheck && corepack pnpm test",
    "smoke": "corepack pnpm build:libs && corepack pnpm typecheck && corepack pnpm test",
    "test": "vitest run",
    "test:integration:db": "RUN_DB_INTEGRATION=1 vitest run packages/db/src/integration.test.ts",
    "test:integration:api": "RUN_API_INTEGRATION=1 vitest run apps/web/app/api/integration.test.ts",
    "test:smoke:web": "vitest run apps/web/app/components/component-interactions.test.tsx -t \"web UI smoke\"",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "corepack pnpm --filter @agent-social/db db:generate",
    "db:migrate": "corepack pnpm --filter @agent-social/db db:migrate",
    "db:seed": "corepack pnpm --filter @agent-social/db db:seed",
    "db:studio": "corepack pnpm --filter @agent-social/db db:studio",
    "db:inspect-agent": "corepack pnpm --filter @agent-social/db db:inspect-agent"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "vite": "^8.0.10",
    "vitest": "4.1.5"
  }
}
