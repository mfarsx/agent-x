{
  "name": "@agent-social/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate --schema prisma/schema.prisma && tsc -p tsconfig.json",
    "typecheck": "prisma generate --schema prisma/schema.prisma && tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio --schema prisma/schema.prisma",
    "db:inspect-agent": "tsx scripts/inspect-agent-content.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/pg": "^8.20.0",
    "prisma": "7.8.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
